{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "Mini-UPI — Transaction & Service Monitoring",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "🌐 Nginx Load Balancer",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 80 }] } },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "title": "Nginx Active Connections",
      "type": "stat",
      "targets": [{ "expr": "nginx_connections_active", "legendFormat": "Active", "refId": "A" }]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "orientation": "auto", "textMode": "auto" },
      "title": "Nginx Request Rate",
      "type": "stat",
      "targets": [{ "expr": "rate(nginx_http_requests_total[1m])", "legendFormat": "req/s", "refId": "A" }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 10,
      "title": "💳 Transaction Service",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 11,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "Transaction TPS (Requests/sec)",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(http_server_requests_seconds_count{application=\"transaction-service\"}[1m])", "legendFormat": "{{uri}} [{{status}}]", "refId": "A" }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "palette-classic" } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 12,
      "title": "Transaction Latency P99 (seconds)",
      "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile(0.99, rate(http_server_requests_seconds_bucket{application=\"transaction-service\"}[5m]))", "legendFormat": "P99 {{uri}}", "refId": "A" },
        { "expr": "histogram_quantile(0.95, rate(http_server_requests_seconds_bucket{application=\"transaction-service\"}[5m]))", "legendFormat": "P95 {{uri}}", "refId": "B" }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 5 }] } }, "overrides": [] },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 14 },
      "id": 13,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "orientation": "auto", "textMode": "auto" },
      "title": "Transaction Errors (5xx) Rate",
      "type": "stat",
      "targets": [{ "expr": "rate(http_server_requests_seconds_count{application=\"transaction-service\",status=~\"5..\"}[1m])", "legendFormat": "errors/s", "refId": "A" }]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 14 },
      "id": 14,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "orientation": "auto", "textMode": "auto" },
      "title": "Total Transactions (all time)",
      "type": "stat",
      "targets": [{ "expr": "http_server_requests_seconds_count{application=\"transaction-service\",uri=~\".*/send.*\"}", "legendFormat": "Total", "refId": "A" }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 20,
      "title": "⚙️ All Services — HTTP Overview",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "id": 21,
      "title": "Request Rate by Service",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(http_server_requests_seconds_count[1m])", "legendFormat": "{{application}}", "refId": "A" }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "palette-classic" } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "id": 22,
      "title": "Average Latency by Service",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(http_server_requests_seconds_sum[1m]) / rate(http_server_requests_seconds_count[1m])", "legendFormat": "{{application}}", "refId": "A" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "id": 30,
      "title": "🖥️ JVM Health",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "bytes", "color": { "mode": "palette-classic" } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "id": 31,
      "title": "JVM Heap Memory Used",
      "type": "timeseries",
      "targets": [
        { "expr": "jvm_memory_used_bytes{area=\"heap\"}", "legendFormat": "{{application}} heap", "refId": "A" }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "id": 32,
      "title": "JVM Threads",
      "type": "timeseries",
      "targets": [
        { "expr": "jvm_threads_live_threads", "legendFormat": "{{application}} threads", "refId": "A" }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["mini-upi", "transactions", "monitoring"],
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Mini-UPI — Transaction Monitor",
  "uid": "mini-upi-txn",
  "version": 1
}
