# ═══════════════════════════════════════════
#  Mini UPI Simulator — Environment Variables
#  DO NOT commit this file to version control
# ═══════════════════════════════════════════

# PostgreSQL
POSTGRES_USER=upi_admin
POSTGRES_PASSWORD=upi_secret_2024
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret_2024

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# JWT
JWT_SECRET=miniupi-super-secret-jwt-key-must-be-at-least-256-bits-long-for-hs256
JWT_EXPIRY_MS=86400000

# Service Ports
USER_SERVICE_PORT=8081
WALLET_SERVICE_PORT=8082
TRANSACTION_SERVICE_PORT=8083
NOTIFICATION_SERVICE_PORT=8084
GATEWAY_PORT=8080
